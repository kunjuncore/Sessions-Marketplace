# Django
# Generate a unique value for production, for example:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-django-secret-key
DEBUG=False

# Comma-separated hostnames served by Django behind Nginx.
# For local Docker, keep localhost and 127.0.0.1. In production, add your domain.
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated browser origins allowed to call the API.
# Match the public URL where the frontend is served.
CORS_ALLOWED_ORIGINS=https://localhost,http://localhost,http://127.0.0.1

# Gunicorn
# Recommended production baseline is 2 * CPU cores + 1.
GUNICORN_WORKERS=3

# PostgreSQL
POSTGRES_DB=sessions_db
POSTGRES_USER=sessions_user
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Google OAuth
# Use the same OAuth web client ID for backend verification and frontend login.
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Next.js
# NEXT_PUBLIC_ values are embedded at image build time.
# Rebuild the frontend image after changing either value.
NEXT_PUBLIC_API_URL=https://localhost/api
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id.apps.googleusercontent.com

# Nginx
NGINX_PORT=80
NGINX_HTTPS_PORT=443
